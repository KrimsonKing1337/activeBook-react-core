{
  "compilerOptions": {
    // "noEmit": true,
    "jsx": "react",
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "allowJs": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": true,
    "baseUrl": "./src",
    "declaration": true,
    "outDir": "./lib"
  },
  // "exclude": ["node_modules", "dist", "lib", "d.ts", "testSetup.ts"],
  "exclude": ["node_modules", "dist", "lib"],
  "include": ["./**/*"]
}
