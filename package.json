    "@lottiefiles/dotlottie-web": "^0.58.1",
    "@reduxjs/toolkit": "^2.11.1",
    "classnames": "^2.3.2",
    "encrypt-storage": "^2.12.16",
    "hammerjs": "^2.0.8",
    "howler": "^2.2.3",
    "lodash-es": "^4.17.21",
    "modern-css-reset": "^1.4.0",
    "moment": "^2.29.4",
    "nanoid": "^5.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-fast-compare": "^3.2.2",
    "react-range": "^1.10.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.10.1",
    "react-router-dom": "^7.10.1",
    "react-toastify": "^11.0.5",
    "redux-saga": "^1.4.2"
